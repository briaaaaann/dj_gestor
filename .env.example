# Servidor
PORT=3000

# Redis (Render Key Value → connection string)
REDIS_URL=redis://localhost:6379

# PIN de acceso al panel del DJ (cámbialo)
DJ_PIN=1234

# Cloudinary (copia la URL desde tu dashboard → Settings → Access Keys)
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@tu_cloud_name
